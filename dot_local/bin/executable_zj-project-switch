#!/bin/sh

set -eu

require() {
    if ! command -v "$1" >/dev/null 2>&1; then
        printf '%s is required\n' "$1" >&2
        exit 1
    fi
}

pick_project() {
    if command -v fzf >/dev/null 2>&1; then
        zoxide query -l | fzf --height=40% --layout=reverse --prompt='Project > '
        return
    fi

    if command -v sk >/dev/null 2>&1; then
        zoxide query -l | sk --height=40% --layout=reverse --prompt='Project > '
        return
    fi

    printf 'fzf or sk is required\n' >&2
    exit 1
}

tab_name_for_path() {
    case "$1" in
        "$HOME")
            printf '~\n'
            ;;
        "$HOME"/*)
            printf '~/%s\n' "${1#"$HOME"/}"
            ;;
        *)
            printf '%s\n' "$1"
            ;;
    esac
}

require zellij
require zoxide

project_path="$(pick_project || true)"

if [ -z "$project_path" ]; then
    exit 0
fi

tab_name="$(tab_name_for_path "$project_path")"
existing_tabs="$(zellij action query-tab-names || true)"

if printf '%s\n' "$existing_tabs" | grep -Fx -- "$tab_name" >/dev/null 2>&1; then
    zellij action go-to-tab-name "$tab_name"
else
    if ! zellij action new-tab --cwd "$project_path" --name "$tab_name" --layout project; then
        zellij action new-tab --cwd "$project_path" --name "$tab_name"
    fi
fi

zoxide add "$project_path" >/dev/null 2>&1 || true
