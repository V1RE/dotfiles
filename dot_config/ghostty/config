font-codepoint-map = U+E5FE-U+FC16 = nielsicon
font-family = "CaskaydiaCove Nerd Font Mono"
font-family = "PragmataPro Liga"
font-family = "PragmataPro Mono Liga"
font-family = "Cascadia Code"
font-family = "CaskaydiaCove Nerd Font"
font-family = "Noto Color Emoji"
font-family = "JetBrains Mono"

font-size = 14
adjust-cell-height = 40%
adjust-cursor-height = 40%

# Window appearance
window-theme = "system"
background-opacity = 0.8
# background-blur-radius = 20
background-blur = true
macos-titlebar-style = "tabs"
window-padding-x = 8
window-padding-y = 8

mouse-hide-while-typing = true

shell-integration = zsh
shell-integration-features = true

# Color scheme (using Catppuccin Macchiato)
theme = "Catppuccin Macchiato"

command = "/opt/zerobrew/bin/zsh"

auto-update-channel = "tip"
keybind = global:cmd+backquote=toggle_quick_terminal

# Send WezTerm-style cmd shortcuts to Herdr using Kitty keyboard protocol.
keybind = cmd+b=text:\x1b[98;9u
keybind = cmd+h=text:\x1b[104;9u
keybind = cmd+j=text:\x1b[106;9u
keybind = cmd+k=text:\x1b[107;9u
keybind = cmd+l=text:\x1b[108;9u
keybind = cmd+m=text:\x1b[109;9u
keybind = cmd+n=text:\x1b[110;9u
keybind = cmd+p=text:\x1b[112;9u

# WezTerm shift-enter behavior.
keybind = shift+enter=text:\x1b\r

macos-option-as-alt = true
