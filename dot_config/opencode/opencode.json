{
  "$schema": "https://opencode.ai/config.json",
  "autoupdate": "notify",
  "experimental": {
    "batch_tool": true,
    "openTelemetry": true
  },
  "formatter": true,
  "username": "Niels",
  "mcp": {
    "servers": {
      "granola": {
        "type": "remote",
        "url": "https://mcp.granola.ai/mcp",
        "disabled": true
      },
      "posthog": {
        "type": "remote",
        "url": "https://mcp.posthog.com/mcp",
        "headers": {
          "Authorization": "Bearer {env:POSTHOG_MCP_KEY}",
          "x-posthog-mcp-mode": "cli"
        },
        "disabled": true
      },
      "slack": {
        "type": "remote",
        "url": "https://mcp.slack.com/mcp",
        "oauth": {
          "client_id": "1601185624273.8899143856786",
          "redirect_uri": "http://localhost:3118/callback"
        },
        "disabled": true
      },
      "gh_grep": {
        "type": "remote",
        "url": "https://mcp.grep.app",
        "disabled": true
      },
      "context7": {
        "url": "https://mcp.context7.com/mcp",
        "type": "remote",
        "headers": {
          "CONTEXT7_API_KEY": "{env:CONTEXT7_API_KEY}"
        },
        "disabled": true
      },
      "websearch-exa": {
        "type": "remote",
        "url": "https://mcp.exa.ai/mcp?tools=web_search_exa",
        "disabled": false
      },
      "codemogger": {
        "type": "local",
        "command": ["codemogger", "mcp"],
        "disabled": false
      }
    }
  },
  "references": {
    "effect": {
      "repository": "Effect-TS/effect-smol"
    },
    "alchemy": {
      "repository": "alchemy-run/alchemy-effect"
    },
    "opencode": {
      "repository": "anomalyco/opencode"
    }
  },
  "agents": {
    "plan": {
      "permissions": [
        {
          "action": "external_directory",
          "resource": "*",
          "effect": "allow"
        }
      ]
    },
    "explore": {
      "permissions": [
        {
          "action": "external_directory",
          "resource": "*",
          "effect": "allow"
        },
        {
          "action": "batch",
          "resource": "*",
          "effect": "deny"
        }
      ]
    },
    "general": {
      "permissions": [
        {
          "action": "external_directory",
          "resource": "*",
          "effect": "allow"
        }
      ]
    }
  },
  "plugins": ["opencode-wakatime", "@2digits/opencode-plugin"],
  "permissions": [
    {
      "action": "websearch",
      "resource": "*",
      "effect": "allow"
