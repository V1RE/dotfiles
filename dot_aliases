#!/bin/bash

# General
alias v='$EDITOR'

alias cm="chezmoi"

# Dotfiles
alias dots="chezmoi edit --watch --apply"

# Listing files
if command -v eza >/dev/null 2>&1; then
	alias ls="eza --icons --color=always --classify --git --group-directories-first --git-ignore"
	alias l="ls --oneline"
	alias ll="ls --long"
	alias la="ll -a"
	alias tree="ll --tree --level=3"
fi

alias tlr="taze latest --recursive"
alias tlri="taze latest --recursive --write --install"

alias nr="FORCE_COLORS=1 nr"

# Git
alias lg="lazygit"
alias gitroot="git rev-parse --show-toplevel"
alias cdr='cd $(gitroot)'

if command -v trash >/dev/null 2>&1; then
	alias rm="trash"
fi

if command -v bat >/dev/null 2>&1; then
	alias cat="bat"
fi

if command -v gping >/dev/null 2>&1; then
	alias ping="gping"
fi

if command -v zed-preview >/dev/null 2>&1; then
	alias zed="zed-preview"
fi

alias oc="opencode"

function ocw() {
	local host="${1:-opencode-worker-01.exe.xyz}"
	local port="${OPENCODE_WORKER_PORT:-4096}"
	local password
	local tunnel_pid
	local status

	if ! command -v opencode >/dev/null 2>&1; then
		echo "opencode is not installed locally" >&2
		return 1
	fi

	password="$(ssh "$host" '. ~/.config/opencode/server.env; printf %s "$OPENCODE_SERVER_PASSWORD"')" || return
	ssh -N -L "${port}:127.0.0.1:4096" "$host" &
	tunnel_pid=$!
	sleep 1
	if ! kill -0 "$tunnel_pid" 2>/dev/null; then
		echo "failed to open SSH tunnel to $host" >&2
		return 1
	fi

	opencode attach "http://127.0.0.1:${port}" --username opencode --password "$password"
	status=$?
	kill "$tunnel_pid" 2>/dev/null || true
	wait "$tunnel_pid" 2>/dev/null || true
	return "$status"
}

alias npx="bunx"

function ctxup() {
	local ctx_dir="$HOME/.ctx"

	fd -HI -t d -d 2 --glob '.git' "$ctx_dir" --format '{//}' | parallel --bar --tag '
    cd {} &&
    git fetch --all --prune &&
    git reset --hard origin/$(git rev-parse --abbrev-ref origin/HEAD | sed "s|origin/||") &&
    git clean -fd
  ' 2>&1
}
